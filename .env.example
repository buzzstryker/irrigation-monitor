# Hydrawise API
HYDRAWISE_API_KEY=

# Database path (SQLite via sql.js)
DB_PATH=./irrigation.db

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Supabase (cloud sync)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Owner phone number (for alerts and default recipient)
OWNER_PHONE=

# Express server port
PORT=3001

# Loomis, CA coordinates for Open-Meteo
LATITUDE=38.8024
LONGITUDE=-121.1964
ELEVATION_M=122
